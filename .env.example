# FitNova Sales Call Intelligence - environment configuration
#
# Copy this file to `.env` and adjust values for your machine. Nothing in
# this project reads secrets or infra settings from Python literals - it
# all comes from here (see fitnova.core.config.Settings and
# docs/01_PHASE1_DESIGN.md Section 13 "Configuration Externalization").

# ---- General -----------------------------------------------------------
APP_ENV=local
LOG_LEVEL=INFO
LOG_FORMAT=console

# ---- Database ------------------------------------------------------------
DATABASE_URL=sqlite:///data/fitnova.db
SQL_ECHO=false

# ---- Filesystem locations ------------------------------------------------
DATA_DIR=data
AUDIO_INBOX_DIR=data/audio/inbox
PROCESSED_AUDIO_DIR=data/processed

# ---- Config files (schema-validated at bootstrap) ------------------------
WEIGHTS_CONFIG_PATH=config/weights.yaml
ISSUE_RULES_CONFIG_PATH=config/issue_rules.yaml
PROMPTS_DIR=src/fitnova/analysis/prompts

# ---- Speech pipeline (faster-whisper) ------------------------------------
# Starting point for the automatic fallback cascade: large-v3 -> medium ->
# small -> base -> tiny. If loading/transcribing with this model fails
# (OOM, corrupt cache, transient error), the engine steps down to the next
# smaller model in the canonical order until one succeeds.
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ---- Diarization -----------------------------------------------------------
DIARIZATION_BACKEND=fallback
HUGGINGFACE_TOKEN=
VAD_AGGRESSIVENESS=2
VAD_FRAME_MS=30
SPEAKER_GAP_MERGE_SECONDS=0.6
MIN_TURN_DURATION_SECONDS=0.3
FIRST_SPEAKER_IS_ADVISOR=true

# ---- Audio validation ------------------------------------------------------
MIN_CALL_DURATION_SECONDS=3.0
SILENCE_RMS_THRESHOLD=0.01

# ---- Call classification (rule-based, Phase 3) ------------------------------
SUPPORTED_LANGUAGES=en,hi
WRONG_NUMBER_MAX_DURATION_SECONDS=20.0
WRONG_NUMBER_MAX_WORDS=25
INTERNAL_CALL_KEYWORDS=standup,internal call,team sync,daily sync,internal meeting

# ---- LLM (Ollama + Qwen3, local) -----------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=120
# Confidence calibration: numeric LLM confidence >= HIGH threshold -> HIGH,
# >= LOW threshold -> MEDIUM, below LOW threshold -> LOW.
CONFIDENCE_HIGH_THRESHOLD=0.8
CONFIDENCE_LOW_THRESHOLD=0.5

# ---- Privacy / pipeline behavior -----------------------------------------
PII_REDACTION_ENABLED=true
MAX_PROCESSING_RETRIES=3
IDEMPOTENCY_HASH_ALGO=sha256

# ---- Service ports ---------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8501
