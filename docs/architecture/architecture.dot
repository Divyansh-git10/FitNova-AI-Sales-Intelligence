digraph FitNovaArchitecture {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", shape=box, style="rounded,filled", fillcolor="#f1f5f9", color="#334155", fontsize=11];
    edge [fontname="Helvetica", fontsize=9, color="#64748b"];
    graph [fontsize=13, labelloc=t, label="FitNova Sales Call Intelligence — Architecture\n(rendered from docs/01_PHASE1_DESIGN.md Section 4.4)", pad=0.4];

    subgraph cluster_sources {
        label="Call Sources (pluggable)";
        style="rounded"; color="#94a3b8";
        s1 [label="Folder of Files"];
        s2 [label="CRM Export"];
        s3 [label="Telephony / Dialer\n(future adapter)", style="rounded,dashed"];
    }

    subgraph cluster_ingest {
        label="Ingestion Layer";
        style="rounded"; color="#94a3b8";
        adp [label="IngestionAdapter\nnormalizes to RawCallRecord"];
        hash [label="Content-hash check\n(idempotency gate)", fillcolor="#fecaca", color="#991b1b"];
    }

    subgraph cluster_speech {
        label="Speech Pipeline";
        style="rounded"; color="#94a3b8";
        asr [label="Transcription\nfaster-whisper"];
        dia [label="Diarization\npyannote OR fallback VAD"];
        norm [label="Transcript Normalization\nspeaker labels + timestamps"];
        pii [label="PII Redaction\n(before LLM ever sees it)"];
    }

    subgraph cluster_classify {
        label="Call Classification";
        style="rounded"; color="#94a3b8";
        cls [label="call_type detector\nSALES / WRONG_NUMBER / INTERNAL /\nNO_SPEECH / UNSUPPORTED_LANGUAGE /\nPENDING_METADATA"];
    }

    subgraph cluster_ai {
        label="AI Analysis Engine (Ollama + Qwen3)";
        style="rounded"; color="#94a3b8";
        score [label="Scoring Engine\n9 rubric dimensions", fillcolor="#ddd6fe", color="#5b21b6"];
        issue [label="Issue Detector\n10-type taxonomy, structured JSON", fillcolor="#ddd6fe", color="#5b21b6"];
        valid [label="Evidence Validator\nquote must exist verbatim\nin transcript", fillcolor="#fecaca", color="#991b1b"];
        insight [label="Insight Generator\nsummary, coaching,\nnext best action", fillcolor="#ddd6fe", color="#5b21b6"];
    }

    db [label="fitnova.db\n(SQLite, SQLAlchemy)", shape=cylinder, fillcolor="#bfdbfe", color="#1e40af"];
    skip [label="Skip — logged\nas duplicate", fillcolor="#e2e8f0"];

    subgraph cluster_surface {
        label="Surfacing";
        style="rounded"; color="#94a3b8";
        api [label="FastAPI\nREST layer"];
        cli [label="Typer CLI"];
        dash [label="Streamlit Dashboard\nDirector / Team Leader / Advisor views"];
    }

    rev [label="Contest / Confirm flag\nAdvisor + Team Leader", shape=box, style="rounded,filled", fillcolor="#fef3c7", color="#92400e"];

    s1 -> adp; s2 -> adp; s3 -> adp [style=dashed];
    adp -> hash;
    hash -> asr [label="new call"];
    hash -> skip [label="duplicate,\nalready processed"];
    asr -> dia -> norm -> pii -> cls;
    cls -> score [label="SALES call"];
    cls -> issue [label="SALES call"];
    cls -> db [label="non-sales"];
    issue -> valid;
    valid -> db [label="verified only"];
    score -> insight -> db;
    db -> api;
    api -> dash;
    api -> cli;
    dash -> rev -> db;

    { rank=same; s1; s2; s3; }
}
